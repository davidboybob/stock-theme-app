# ──────────────────────────────────────────────
# Supabase (필수)
# https://supabase.com/dashboard → 프로젝트 Settings → API
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key   # service_role 키 사용 (RLS 비활성화 상태)

# ──────────────────────────────────────────────
# CORS — 프론트엔드 도메인 (콤마 구분)
# 로컬: http://localhost:5173,http://localhost:3000
# 프로덕션: https://your-app.vercel.app
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────
# 프론트엔드 환경변수 (Vercel / 로컬 개발)
# docker-compose로 실행 시: 빈 값 유지 (nginx가 /api/ 프록시 처리)
# Vercel 배포 시: 백엔드 Render URL 입력
# ──────────────────────────────────────────────
VITE_API_URL=
