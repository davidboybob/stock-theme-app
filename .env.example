# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# CORS (Vercel 배포 URL로 설정)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Frontend
VITE_API_URL=https://your-backend.onrender.com
VITE_WS_URL=wss://your-backend.onrender.com

# 토스증권 Open API (WTS 설정 > Open API 에서 발급)
# 주의: 공개 배포 환경에는 절대 설정하지 말 것. 로컬/개인 서버 전용.
TRADING_ENABLED=false
TOSS_CLIENT_ID=your-toss-client-id
TOSS_CLIENT_SECRET=your-toss-client-secret

# 자동매매 봇 (Phase 3) — 기본 dry-run(시그널 기록만)
# BOT_LIVE_TRADING=true 로 바꿔야만 실주문 전환 가능. 최소 1주일 dry-run 후 전환 권장.
BOT_LIVE_TRADING=false
BOT_INTERVAL_MINUTES=5
BOT_THEME_THRESHOLD=2.0
BOT_ORDER_BUDGET=100000
BOT_MAX_SIGNALS_PER_DAY=20
